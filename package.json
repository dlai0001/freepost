{
  "name": "freepost",
  "version": "0.1.0",
  "description": "The API client that never phones home. Open-source Postman alternative; collections are runnable curl files on disk.",
  "license": "MIT",
  "author": "dlaisoft <david@dlaisoft.com>",
  "private": true,
  "main": "./out/main/index.js",
  "bin": {
    "freepost": "./out/cli/index.mjs"
  },
  "homepage": "https://dlai0001.github.io/freepost/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dlai0001/freepost.git"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "electron-vite dev",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:cli": "vite build --config vite.cli.config.ts",
    "build:unpack": "electron-vite build && electron-builder --dir",
    "build:win": "electron-vite build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "cli": "node out/cli/index.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "fence": "node scripts/check-network-fence.mjs",
    "verify": "npm run typecheck && npm run test && npm run fence && npm run build && npm run build:cli"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.7.15",
    "chai": "^6.2.2",
    "cm6-graphql": "^0.2.1",
    "graphql": "^16.14.2",
    "graphql-sse": "^2.6.0",
    "graphql-ws": "^6.0.8",
    "js-yaml": "^5.2.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.1",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.6",
    "@types/chai": "^5.2.3",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^5.2.0",
    "codemirror": "^6.0.2",
    "electron": "^43.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  }
}
